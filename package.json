{
  "name": "mcp-security-scanner",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-security-scanner": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "npm run build && node test/mcp-behavior.test.mjs",
    "prepare": "npm run build"
  },
  "description": "MCP server for scanning JavaScript/TypeScript projects for security vulnerabilities including memory issues, insecure file operations, unsafe plugin loading, command injection, and configuration weaknesses.",
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "vulnerability",
    "model-context-protocol",
    "stdio",
    "streamable-http"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DMontgomery40/mcp-security-scanner"
  },
  "author": "David Montgomery",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
